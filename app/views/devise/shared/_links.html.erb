<%- if controller_name != 'sessions' %>
  <p><%= link_to "Log in", new_session_path(resource_name), class: "font-semibold text-cyan-700 transition hover:text-cyan-600" %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p><%= link_to "Sign up", new_registration_path(resource_name), class: "font-semibold text-cyan-700 transition hover:text-cyan-600" %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p><%= link_to "Forgot your password?", new_password_path(resource_name), class: "font-semibold text-cyan-700 transition hover:text-cyan-600" %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p><%= link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "font-semibold text-cyan-700 transition hover:text-cyan-600" %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p><%= link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "font-semibold text-cyan-700 transition hover:text-cyan-600" %></p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p><%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100" %></p>
  <% end %>
<% end %>
