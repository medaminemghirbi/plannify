<%= form_with model: @payment do |f| %>
  <% if @payment.errors.any? %>
    <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 p-4">
      <h3 class="text-sm font-bold text-rose-800"><%= pluralize(@payment.errors.count, "error") %> prevented saving:</h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
        <% @payment.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :client_id, "Client", class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.collection_select :client_id, @clients, :id, :full_name, { prompt: "Select client" }, { required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" } %>
  </div>

  <div class="mb-4">
    <%= f.label :amount, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.number_field :amount, step: 0.01, min: 0, required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :starts_on, "Start date", class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.date_field :starts_on, required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :duration_months, "Duration", class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.select :duration_months, @duration_options, {}, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :status, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.select :status, @status_options, {}, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-5">
    <%= f.label :notes, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.text_area :notes, rows: 3, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="pt-1">
    <%= f.submit class: "rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700" %>
  </div>
<% end %>
