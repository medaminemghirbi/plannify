<div class="mx-auto max-w-7xl space-y-6">
  <section class="rounded-3xl border border-slate-200 bg-white px-5 py-5 shadow-sm sm:px-6">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
      <div class="space-y-2">
        <div class="inline-flex items-center rounded-full bg-cyan-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-700">
          Finance
        </div>
        <div>
          <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Payments</h1>
          <p class="mt-1 max-w-2xl text-sm text-slate-500">Filter by month and year, review revenue, and manage each payment from a single workspace.</p>
          <div class="mt-2 inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-700">
            Currency: <span class="ml-1 font-black text-slate-900"><%= @default_currency %></span>
          </div>
        </div>
      </div>

      <%= link_to "New payment", new_payment_path, class: "inline-flex items-center justify-center rounded-full bg-cyan-700 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-cyan-600" %>
    </div>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
    <%= form_with url: payments_path, method: :get, local: true, class: "grid gap-4 md:grid-cols-2 xl:grid-cols-6 xl:items-end" do %>
      <div>
        <label class="mb-1.5 block text-sm font-semibold text-slate-700">Month</label>
        <%= select_tag :month, options_for_select([["All months", ""]] + @month_options, @selected_month), class: "w-full rounded-2xl border border-slate-300 bg-white px-3 py-2.5 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
      </div>

      <div>
        <label class="mb-1.5 block text-sm font-semibold text-slate-700">Year</label>
        <%= select_tag :year, options_for_select([["All years", ""]] + @year_options.map { |year| [year, year] }, @selected_year), class: "w-full rounded-2xl border border-slate-300 bg-white px-3 py-2.5 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
      </div>

      <div>
        <label class="mb-1.5 block text-sm font-semibold text-slate-700">Gym</label>
        <%= select_tag :gym_id, options_for_select([["All gyms", ""]] + @gym_options, @selected_gym_id), class: "w-full rounded-2xl border border-slate-300 bg-white px-3 py-2.5 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
      </div>

      <div>
        <label class="mb-1.5 block text-sm font-semibold text-slate-700">Group</label>
        <%= select_tag :group_id, options_for_select([["All groups", ""]] + @group_options, @selected_group_id), class: "w-full rounded-2xl border border-slate-300 bg-white px-3 py-2.5 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
      </div>

      <div>
        <label class="mb-1.5 block text-sm font-semibold text-slate-700">Per page</label>
        <%= select_tag :per_page, options_for_select(PaymentsController::PAGE_SIZES.map { |size| [size, size] }, @selected_page_size), class: "w-full rounded-2xl border border-slate-300 bg-white px-3 py-2.5 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
      </div>

      <div class="flex flex-wrap gap-2 xl:justify-end">
        <%= submit_tag "Apply", class: "inline-flex items-center justify-center rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700 whitespace-nowrap" %>
        <%= link_to "Reset", payments_path, class: "inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 whitespace-nowrap" %>
      </div>
    <% end %>
  </section>

  <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Revenue</p>
      <p class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900"><%= format_money(@revenue_total, currency: @default_currency) %></p>
      <p class="mt-1 text-sm text-slate-500">
        <%= @selected_month.present? ? Date::MONTHNAMES[@selected_month.to_i] : "All months" %>
        · <%= @selected_year.present? ? @selected_year : "All years" %>
      </p>
    </article>

    <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Results</p>
      <p class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900"><%= @payments_count %></p>
      <p class="mt-1 text-sm text-slate-500">Showing <%= @payments.length %> on this page</p>
    </article>

    <article class="rounded-3xl border border-slate-200 bg-slate-50 p-5 shadow-sm md:col-span-2 xl:col-span-1">
      <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">View</p>
      <p class="mt-2 text-sm font-semibold text-slate-900">Filtered payments</p>
      <p class="mt-1 text-sm text-slate-500">Use the controls above to narrow by period and page size.</p>
    </article>
  </section>

  <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="sticky top-0 bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-4">Client</th>
            <th class="px-5 py-4">Gyms</th>
            <th class="px-5 py-4">Amount</th>
            <th class="px-5 py-4">Period</th>
            <th class="px-5 py-4">Status</th>
            <th class="px-5 py-4 text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white">
          <% @payments.each do |payment| %>
            <tr class="hover:bg-slate-50/70">
              <td class="px-5 py-4 font-semibold text-slate-900"><%= payment.client.full_name %></td>
              <td class="px-5 py-4 text-slate-600">
                <% gym_names = payment.client.client_in_gyms.map(&:name) %>
                <% if gym_names.any? %>
                  <div class="flex flex-wrap gap-2">
                    <% gym_names.each do |gym_name| %>
                      <span class="inline-flex rounded-full bg-cyan-50 px-2.5 py-1 text-xs font-semibold text-cyan-700"><%= gym_name %></span>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-sm text-slate-400">Not affected to any gym</span>
                <% end %>
              </td>
              <% payment_currency = payment.client.client_in_gyms.first&.currency || @default_currency %>
              <td class="px-5 py-4 text-slate-700"><%= format_money(payment.amount, currency: payment_currency) %></td>
              <td class="px-5 py-4 text-slate-600"><%= payment.starts_on %> to <%= payment.ends_on %> (<%= payment.duration_label %>)</td>
              <td class="px-5 py-4">
                <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700"><%= payment.status %></span>
              </td>
              <td class="px-5 py-4 text-right">
                <div class="inline-flex flex-nowrap items-center gap-2">
                  <% if payment.paid? %>
                    <% if payment.receipt.present? %>
                      <%= link_to "Receipt", payment_receipt_path(payment), class: "inline-flex shrink-0 whitespace-nowrap rounded-full border border-emerald-200 px-3 py-1.5 text-xs font-semibold text-emerald-700 transition hover:bg-emerald-50" %>
                    <% else %>
                      <%= link_to "Generate receipt", new_payment_receipt_path(payment), class: "inline-flex shrink-0 whitespace-nowrap rounded-full border border-amber-200 px-3 py-1.5 text-xs font-semibold text-amber-700 transition hover:bg-amber-50" %>
                    <% end %>
                  <% else %>
                    <span class="inline-flex shrink-0 whitespace-nowrap rounded-full border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-400">Receipt after paid</span>
                  <% end %>
                  <%= link_to "Edit", edit_payment_path(payment), class: "inline-flex shrink-0 whitespace-nowrap rounded-full border border-cyan-200 px-3 py-1.5 text-xs font-semibold text-cyan-700 transition hover:bg-cyan-50" %>
                  <%= button_to "Delete", payment_path(payment), method: :delete, data: { turbo_confirm: "Delete this payment?" }, class: "inline-flex shrink-0 whitespace-nowrap rounded-full border border-rose-200 px-3 py-1.5 text-xs font-semibold text-rose-700 transition hover:bg-rose-50" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="flex flex-col gap-3 rounded-3xl border border-slate-200 bg-white px-5 py-4 shadow-sm sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm text-slate-600">
      Page <span class="font-semibold text-slate-900"><%= @current_page %></span> of <span class="font-semibold text-slate-900"><%= @total_pages.zero? ? 1 : @total_pages %></span>
    </p>

    <div class="inline-flex flex-wrap gap-2">
      <%= link_to "Previous",
        payments_path(request.query_parameters.merge(page: @current_page - 1)),
        class: "inline-flex min-w-24 items-center justify-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 #{'pointer-events-none opacity-40' if @current_page <= 1}" %>

      <%= link_to "Next",
        payments_path(request.query_parameters.merge(page: @current_page + 1)),
        class: "inline-flex min-w-24 items-center justify-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50 #{'pointer-events-none opacity-40' if @total_pages.zero? || @current_page >= @total_pages}" %>
    </div>
  </section>
</div>
