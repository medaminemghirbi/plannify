<div class="space-y-5">
  <section class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900"><%= t("gyms.title") %></h1>
    <%= link_to t("gyms.new_title"), new_gym_path, class: "rounded-full bg-cyan-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-cyan-600" %>
  </section>

  <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="bg-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">
          <tr>
            <th class="px-4 py-3"><%= t("gyms.logo") %></th>
            <th class="px-4 py-3"><%= t("ui.name") %></th>
            <th class="px-4 py-3"><%= t("gyms.address") %></th>
            <th class="px-4 py-3"><%= t("gyms.currency") %></th>
            <th class="px-4 py-3"><%= t("gyms.admin") %></th>
            <th class="px-4 py-3"><%= t("ui.actions") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @gyms.each do |gym| %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3">
                <% if gym.logo.attached? %>
                  <%= image_tag gym.logo, class: "h-10 w-10 rounded-xl object-cover ring-1 ring-slate-200" %>
                <% else %>
                  <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 text-xs font-bold text-slate-500"><%= t("gyms.placeholder") %></div>
                <% end %>
              </td>
              <td class="px-4 py-3 font-semibold text-slate-900"><%= gym.name %></td>
              <td class="px-4 py-3 text-slate-600"><%= gym.address.presence || "-" %></td>
              <td class="px-4 py-3 text-slate-600"><%= gym.currency %></td>
              <td class="px-4 py-3 text-slate-600"><%= gym.admin.full_name %></td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-2">
                  <%= link_to t("actions.show"), gym_path(gym), class: "rounded-full border border-slate-200 px-3 py-1 font-semibold text-slate-700 transition hover:bg-slate-100" %>
                  <%= link_to t("actions.edit"), edit_gym_path(gym), class: "rounded-full border border-cyan-200 px-3 py-1 font-semibold text-cyan-700 transition hover:bg-cyan-50" %>
                  <%= button_to t("actions.delete"), gym_path(gym), method: :delete, data: { turbo_confirm: t("gyms.delete_confirm") }, class: "rounded-full border border-rose-200 px-3 py-1 font-semibold text-rose-700 transition hover:bg-rose-50" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
