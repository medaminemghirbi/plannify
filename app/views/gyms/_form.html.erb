<%= form_with model: @gym do |f| %>
  <% if @gym.errors.any? %>
    <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 p-4">
      <h3 class="text-sm font-bold text-rose-800"><%= t("forms.error_count", count: @gym.errors.count) %></h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
        <% @gym.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :name, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.text_field :name, required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :address, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.text_field :address, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :currency, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.select :currency, options_for_select(money_currency_options, @gym.currency), {}, class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-5">
    <%= f.label :logo, t("gyms.select_logo"), class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.file_field :logo, accept: "image/*", class: "block w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm text-slate-700 file:mr-4 file:rounded-full file:border-0 file:bg-cyan-50 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-cyan-700 hover:file:bg-cyan-100" %>
    <% if @gym.logo.attached? %>
      <div class="mt-3 flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-3">
        <%= image_tag @gym.logo, class: "h-12 w-12 rounded-xl object-cover" %>
        <div>
          <p class="text-sm font-semibold text-slate-900"><%= t("gyms.current_logo") %></p>
          <p class="text-xs text-slate-500"><%= t("gyms.replace_logo") %></p>
        </div>
      </div>
    <% end %>
  </div>

  <% if current_user.superadmin? %>
    <div class="mb-5">
      <%= f.label :admin_id, t("gyms.admin"), class: "mb-1 block text-sm font-semibold text-slate-700" %>
      <%= f.collection_select :admin_id, User.admins.order(:full_name), :id, :full_name, { prompt: t("gyms.select_admin") }, { required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" } %>
    </div>
  <% end %>

  <div class="pt-1">
    <%= f.submit class: "rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700" %>
  </div>
<% end %>
