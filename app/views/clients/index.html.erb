<div class="space-y-5">
  <section class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900"><%= t("nav.items.clients") %></h1>
    <%= link_to t("actions.new_client"), new_client_path, class: "rounded-full bg-cyan-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-cyan-600" %>
  </section>

  <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="bg-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">
          <tr>
            <th class="px-4 py-3"><%= t("ui.name") %></th>
            <th class="px-4 py-3"><%= t("ui.email") %></th>
            <th class="px-4 py-3"><%= t("ui.phone") %></th>
            <th class="px-4 py-3"><%= t("ui.groups") %></th>
            <th class="px-4 py-3"><%= t("ui.gym") %></th>
            <th class="px-4 py-3"><%= t("ui.actions") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @clients.each do |client| %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3 font-semibold text-slate-900"><%= client.full_name %></td>
              <td class="px-4 py-3 text-slate-600"><%= client.email %></td>
              <td class="px-4 py-3 text-slate-600"><%= client.phone_number || "-" %></td>
              <td class="px-4 py-3 text-slate-600">
                <% if client.groups.any? %>
                  <div class="flex flex-wrap gap-2">
                    <% client.groups.each do |group| %>
                      <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
                        <%= group.name %>
                      </span>
                    <% end %>
                  </div>
                <% else %>
                    <span class="text-sm text-slate-400"><%= t("clients.no_groups") %></span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-slate-600"><%= client.gym&.name || "-" %></td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-2">
                  <%= link_to t("actions.edit"), edit_client_path(client), class: "rounded-full border border-cyan-200 px-3 py-1 text-xs font-semibold text-cyan-700 transition hover:bg-cyan-50" %>
                  <%= button_to t("actions.delete"), client_path(client), method: :delete, data: { turbo_confirm: t("clients.delete_confirm") }, class: "rounded-full border border-rose-200 px-3 py-1 text-xs font-semibold text-rose-700 transition hover:bg-rose-50" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
