<div class="space-y-5">
  <section class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Clients</h1>
    <%= link_to "Add Client", new_client_path, class: "rounded-full bg-cyan-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-cyan-600" %>
  </section>

  <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="bg-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">
          <tr>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">Email</th>
            <th class="px-4 py-3">Phone</th>
            <th class="px-4 py-3">Groups</th>
            <th class="px-4 py-3">Gyms</th>
            <th class="px-4 py-3">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @clients.each do |client| %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3 font-semibold text-slate-900"><%= client.full_name %></td>
              <td class="px-4 py-3 text-slate-600"><%= client.email %></td>
              <td class="px-4 py-3 text-slate-600"><%= client.phone_number || "-" %></td>
              <td class="px-4 py-3 text-slate-600">
                <% if client.groups.any? %>
                  <div class="flex flex-wrap gap-2">
                    <% client.groups.each do |group| %>
                      <span class="inline-flex rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">
                        <%= group.name %>
                      </span>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-sm text-slate-400">Not affected to any group</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-slate-600">
                <span class="inline-flex rounded-full bg-cyan-100 px-2 py-1 text-xs font-semibold text-cyan-700">
                  <%= client.client_in_gyms.count %>
                </span>
              </td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-2">
                  <%= link_to "Edit", edit_client_path(client), class: "rounded-full border border-cyan-200 px-3 py-1 text-xs font-semibold text-cyan-700 transition hover:bg-cyan-50" %>
                  <%= button_to "Delete", client_path(client), method: :delete, data: { turbo_confirm: "Delete this client?" }, class: "rounded-full border border-rose-200 px-3 py-1 text-xs font-semibold text-rose-700 transition hover:bg-rose-50" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
