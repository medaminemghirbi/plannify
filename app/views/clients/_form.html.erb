<%= form_with url: (@client.persisted? ? client_path(@client) : clients_path), method: (@client.persisted? ? :patch : :post), local: true do |f| %>
  <% if @client.errors.any? %>
    <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 p-4">
      <h3 class="text-sm font-bold text-rose-800"><%= pluralize(@client.errors.count, "error") %> prevented saving:</h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
        <% @client.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :full_name, "Full Name", class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.text_field :full_name, required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :email, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.email_field :email, required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-5">
    <%= f.label :phone_number, "Phone Number", class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.telephone_field :phone_number, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-5">
    <%= f.label :gym_ids, "Assign to Gyms", class: "mb-2 block text-sm font-semibold text-slate-700" %>
    <div class="space-y-2">
      <% @gyms.each do |gym| %>
        <label class="flex items-center gap-3">
          <%= check_box_tag "client[gym_ids][]", gym.id, (@client_gym_ids || []).include?(gym.id), class: "h-4 w-4 rounded border-slate-300" %>
          <span class="text-sm text-slate-700"><%= gym.name %></span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="pt-1">
    <%= f.submit class: "rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700" %>
  </div>
<% end %>
