<%= form_with model: @training_group do |f| %>
  <% if @training_group.errors.any? %>
    <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 p-4">
      <h3 class="text-sm font-bold text-rose-800"><%= pluralize(@training_group.errors.count, "error") %> prevented saving:</h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
        <% @training_group.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :name, t("ui.name"), class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.text_field :name, required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :gym_id, t("ui.gym"), class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.collection_select :gym_id, @gyms, :id, :name, { prompt: t("settings.select_gym") }, { required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" } %>
  </div>

  <div class="mb-4">
    <%= f.label :coach_id, t("ui.coach"), class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.collection_select :coach_id, @coaches, :id, :full_name, { prompt: t("settings.select_coach") }, { required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" } %>
  </div>

  <div class="mb-5">
    <%= f.label :capacity, t("training_groups.capacity"), class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.number_field :capacity, min: 1, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="pt-1">
    <%= f.submit t("actions.save"), class: "rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700" %>
  </div>
<% end %>
