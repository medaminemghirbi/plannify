<%= form_with model: @document do |f| %>
  <% if @document.errors.any? %>
    <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 p-4">
      <h3 class="text-sm font-bold text-rose-800"><%= pluralize(@document.errors.count, "error") %> prevented saving:</h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
        <% @document.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :title, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.text_field :title, required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :gym_id, "Gym", class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.collection_select :gym_id, @gyms, :id, :name, { prompt: "Select gym" }, { required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" } %>
  </div>

  <div class="mb-4">
    <%= f.label :kind, "Type", class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.select :kind, @kinds, {}, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :description, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.text_area :description, rows: 4, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-5">
    <%= f.label :file, "Attachment (any type)", class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.file_field :file, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-sm text-slate-700 outline-none ring-cyan-500 transition file:mr-3 file:rounded-lg file:border-0 file:bg-cyan-50 file:px-3 file:py-1.5 file:font-semibold file:text-cyan-800 hover:file:bg-cyan-100 focus:border-cyan-500 focus:ring" %>
    <% if @document.file.attached? %>
      <p class="mt-2 text-xs text-slate-500">Current file: <%= @document.file_name %></p>
    <% end %>
  </div>

  <div class="pt-1">
    <%= f.submit class: "rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700" %>
  </div>
<% end %>
