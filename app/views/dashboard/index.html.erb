<% if current_user.superadmin? %>
  <div class="space-y-6">
    <section class="rounded-3xl bg-gradient-to-r from-slate-950 via-slate-900 to-cyan-900 px-6 py-8 text-white shadow-xl">
      <h1 class="text-3xl font-extrabold tracking-tight">Superadmin Command Dashboard</h1>
      <p class="mt-2 text-cyan-100">
        Welcome <span class="font-bold text-white"><%= current_user.full_name %></span>.
        You can manage admin accounts and global governance.
      </p>
      <div class="mt-5">
        <%= link_to "Manage Admins", admins_path, class: "inline-flex items-center rounded-full bg-white/20 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/30" %>
      </div>
    </section>

    <section class="grid gap-4 sm:grid-cols-2">
      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Total Admins</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @admins_count %></p>
      </article>
      <article class="rounded-2xl border border-cyan-200 bg-cyan-50 p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-wide text-cyan-700">Gyms In Platform</p>
        <p class="mt-2 text-3xl font-extrabold text-cyan-900"><%= @gyms_count %></p>
      </article>
    </section>

    <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-4 py-3">
        <h2 class="text-lg font-bold text-slate-900">Recent Admin Accounts</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">
            <tr>
              <th class="px-4 py-3">Name</th>
              <th class="px-4 py-3">Email</th>
              <th class="px-4 py-3">Created</th>
              <th class="px-4 py-3">Last sign-in</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @recent_admins.each do |admin_user| %>
              <tr>
                <td class="px-4 py-3 font-semibold text-slate-900"><%= admin_user.full_name %></td>
                <td class="px-4 py-3 text-slate-600"><%= admin_user.email %></td>
                <td class="px-4 py-3 text-slate-600"><%= l(admin_user.created_at, format: :short) %></td>
                <td class="px-4 py-3 text-slate-600"><%= admin_user.last_sign_in_at ? l(admin_user.last_sign_in_at, format: :short) : "Never" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
<% else %>
  <div class="space-y-6">
    <section class="rounded-3xl bg-slate-900 px-6 py-8 text-white shadow-xl">
      <h1 class="text-3xl font-extrabold tracking-tight">Gym Dashboard</h1>
      <p class="mt-2 text-slate-200">
        Welcome <span class="font-bold text-white"><%= current_user.full_name %></span>.
        You are connected as <span class="rounded-full bg-white/20 px-2 py-1 text-xs font-bold uppercase"><%= current_user.role %></span>.
      </p>
    </section>

    <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Gyms</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @gyms_count %></p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Coaches</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @coaches_count %></p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Clients</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @clients_count %></p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Groups</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @groups_count %></p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Planning Sessions</p>
        <p class="mt-2 text-3xl font-extrabold text-slate-900"><%= @sessions_count %></p>
      </article>
      <article class="rounded-2xl border border-cyan-200 bg-cyan-50 p-5 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-wide text-cyan-700">Revenue This Month</p>
        <p class="mt-2 text-3xl font-extrabold text-cyan-900"><%= format_money(@monthly_revenue || 0, currency: @dashboard_currency) %></p>
      </article>
    </section>
  </div>
<% end %>
