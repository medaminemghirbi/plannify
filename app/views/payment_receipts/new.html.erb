<div class="mx-auto max-w-5xl space-y-6">
  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">Generate payment receipt</h1>
    <p class="mt-1 text-sm text-slate-500">This receipt is generated once and saved permanently with payment, client, gym, and generator details.</p>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="grid gap-4 md:grid-cols-2">
      <article class="rounded-2xl bg-slate-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Client</p>
        <p class="mt-2 text-lg font-bold text-slate-900"><%= @payment.client.full_name %></p>
        <p class="text-sm text-slate-600"><%= @payment.client.email %></p>
        <p class="text-sm text-slate-600"><%= @payment.client.phone_number.presence || "-" %></p>
      </article>

      <article class="rounded-2xl bg-slate-50 p-4">
        <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Payment</p>
        <% payment_currency = @payment.client.client_in_gyms.first&.currency || "TND" %>
        <p class="mt-2 text-lg font-bold text-slate-900"><%= format_money(@payment.amount, currency: payment_currency) %></p>
        <p class="text-sm text-slate-600"><%= @payment.starts_on %> to <%= @payment.ends_on %> (<%= @payment.duration_label %>)</p>
        <p class="text-sm text-slate-600">Status: <span class="font-semibold"><%= @payment.status %></span></p>
      </article>
    </div>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <%= form_with model: [@payment, @receipt], url: payment_receipt_path(@payment), method: :post, local: true, html: { id: "receipt-form" } do |f| %>
      <% if @receipt.errors.any? %>
        <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 p-4">
          <h3 class="text-sm font-bold text-rose-800"><%= pluralize(@receipt.errors.count, "error") %> prevented saving:</h3>
          <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
            <% @receipt.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid gap-6 lg:grid-cols-2">
        <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
          <h2 class="text-base font-bold text-slate-900">Client signature on paper</h2>
          <p class="mt-1 text-sm text-slate-500">The client will sign manually on the printed receipt after generation.</p>
          <div class="mt-4 rounded-xl border border-dashed border-slate-300 bg-white p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Signature line</p>
            <p class="mt-4 text-sm text-slate-800">Signature client: _________________________________</p>
          </div>
        </article>

        <article class="rounded-2xl border border-slate-200 p-4">
          <h2 class="text-base font-bold text-slate-900">Gym signature</h2>
          <p class="mt-1 text-sm text-slate-500">Gym/admin signs here for the gym.</p>
          <canvas id="gym-signature-pad" class="mt-3 w-full rounded-xl border border-slate-300 bg-white"></canvas>
          <div class="mt-3">
            <button id="clear-gym-signature" type="button" class="rounded-full border border-slate-200 px-4 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-50">Clear gym signature</button>
          </div>
          <%= f.hidden_field :gym_signature_data, id: "gym-signature-data" %>
        </article>
      </div>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <%= f.submit "Generate and save receipt", class: "inline-flex items-center justify-center rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700" %>
        <%= link_to "Back", payments_path, class: "text-sm font-semibold text-slate-600 transition hover:text-slate-900" %>
      </div>
    <% end %>
  </section>
</div>

<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.1.7/dist/signature_pad.umd.min.js"></script>
<script>
  document.addEventListener("turbo:load", function() {
    var form = document.getElementById("receipt-form");
    if (!form || typeof SignaturePad === "undefined") return;

    var gymCanvas = document.getElementById("gym-signature-pad");
    var gymDataInput = document.getElementById("gym-signature-data");
    var clearGymBtn = document.getElementById("clear-gym-signature");

    if (!gymCanvas || !gymDataInput) return;

    function resizeCanvas(canvas) {
      var ratio = Math.max(window.devicePixelRatio || 1, 1);
      var width = canvas.offsetWidth;
      var height = 180;
      canvas.width = width * ratio;
      canvas.height = height * ratio;
      canvas.getContext("2d").scale(ratio, ratio);
    }

    resizeCanvas(gymCanvas);

    var gymPad = new SignaturePad(gymCanvas, { minWidth: 1, maxWidth: 2.2 });

    if (clearGymBtn) {
      clearGymBtn.addEventListener("click", function() {
        gymPad.clear();
        gymDataInput.value = "";
      });
    }

    form.addEventListener("submit", function(event) {
      if (gymPad.isEmpty()) {
        event.preventDefault();
        window.alert("Gym signature is required.");
        return;
      }

      gymDataInput.value = gymPad.toDataURL("image/png");
    });

    window.addEventListener("resize", function() {
      resizeCanvas(gymCanvas);
      gymPad.clear();
      gymDataInput.value = "";
    });
  });
</script>