<% snapshot = @receipt.details_snapshot || {} %>
<% payment_snapshot = snapshot["payment"] || snapshot[:payment] || {} %>
<% client_snapshot = snapshot["client"] || snapshot[:client] || {} %>
<% gyms_snapshot = snapshot["gyms"] || snapshot[:gyms] || [] %>
<% generated_by_snapshot = snapshot["generated_by"] || snapshot[:generated_by] || {} %>
<% currency_code = payment_snapshot["currency"] || payment_snapshot[:currency] || gyms_snapshot.first&.dig("currency") || gyms_snapshot.first&.dig(:currency) || "TND" %>

<div class="mx-auto max-w-5xl space-y-6">
  <section class="flex flex-wrap items-center justify-between gap-3 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div>
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">Payment receipt</h1>
      <p class="mt-1 text-sm text-slate-500">Receipt generated on <%= l(@receipt.generated_at, format: :long) %> and locked for audit.</p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Download PDF", pdf_payment_receipt_path(@payment), class: "rounded-full border border-cyan-200 px-4 py-2 text-sm font-semibold text-cyan-700 transition hover:bg-cyan-50" %>
      <button type="button" onclick="window.print()" class="rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Print</button>
      <%= link_to "Back", payments_path, class: "rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50" %>
    </div>
  </section>

  <section class="rounded-3xl border border-slate-300 bg-white p-6 shadow-sm print:shadow-none">
    <div class="border-b border-slate-200 pb-4 text-center">
      <h2 class="text-2xl font-black uppercase tracking-wide text-slate-900">Recu de paiement</h2>
      <p class="mt-1 text-sm text-slate-600">No. <%= @receipt.id %></p>
    </div>

    <div class="mt-5 grid gap-5 md:grid-cols-2">
      <article class="rounded-2xl border border-slate-200 p-4">
        <h3 class="text-sm font-bold uppercase tracking-wide text-slate-600">Client</h3>
        <dl class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between gap-4"><dt class="text-slate-500">Received from</dt><dd class="font-semibold text-slate-900"><%= client_snapshot["full_name"] || client_snapshot[:full_name] %></dd></div>
          <div class="flex justify-between gap-4"><dt class="text-slate-500">Amount</dt><dd class="font-semibold text-slate-900"><%= format_money(payment_snapshot["amount"] || payment_snapshot[:amount], currency: currency_code) %></dd></div>
          <div class="flex justify-between gap-4"><dt class="text-slate-500">Period</dt><dd class="font-semibold text-slate-900"><%= payment_snapshot["starts_on"] || payment_snapshot[:starts_on] %> to <%= payment_snapshot["ends_on"] || payment_snapshot[:ends_on] %></dd></div>
          <div class="flex justify-between gap-4"><dt class="text-slate-500">Status</dt><dd class="font-semibold text-slate-900"><%= payment_snapshot["status"] || payment_snapshot[:status] %></dd></div>
          <div class="flex justify-between gap-4"><dt class="text-slate-500">Gym(s)</dt><dd class="font-semibold text-slate-900"><%= gyms_snapshot.map { |gym| gym["name"] || gym[:name] }.join(", ").presence || "-" %></dd></div>
        </dl>

        <div class="mt-6">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Client signature</p>
          <div class="mt-2 rounded-xl border border-dashed border-slate-300 bg-white p-4">
            <p class="text-sm text-slate-700">Signature client: _________________________________</p>
            <p class="mt-1 text-xs text-slate-500">Le client signe manuellement sur la version papier.</p>
          </div>
        </div>
      </article>

      <article class="rounded-2xl border border-slate-200 p-4">
        <h3 class="text-sm font-bold uppercase tracking-wide text-slate-600">Gym</h3>
        <dl class="mt-3 space-y-2 text-sm">
          <div class="flex justify-between gap-4"><dt class="text-slate-500">Client</dt><dd class="font-semibold text-slate-900"><%= client_snapshot["full_name"] || client_snapshot[:full_name] %></dd></div>
          <div class="flex justify-between gap-4"><dt class="text-slate-500">Client email</dt><dd class="font-semibold text-slate-900"><%= client_snapshot["email"] || client_snapshot[:email] %></dd></div>
          <div class="flex justify-between gap-4"><dt class="text-slate-500">Client phone</dt><dd class="font-semibold text-slate-900"><%= client_snapshot["phone_number"] || client_snapshot[:phone_number] %></dd></div>
          <div class="flex justify-between gap-4"><dt class="text-slate-500">Generated by</dt><dd class="font-semibold text-slate-900"><%= generated_by_snapshot["full_name"] || generated_by_snapshot[:full_name] %></dd></div>
          <div class="flex justify-between gap-4"><dt class="text-slate-500">Generated at</dt><dd class="font-semibold text-slate-900"><%= snapshot["generated_at"] || snapshot[:generated_at] %></dd></div>
        </dl>

        <div class="mt-6">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Gym signature</p>
          <div class="mt-2 rounded-xl border border-slate-200 bg-white p-2">
            <%= image_tag @receipt.gym_signature_data, alt: "Gym signature", class: "h-24 w-full object-contain" %>
          </div>
        </div>
      </article>
    </div>
  </section>
</div>