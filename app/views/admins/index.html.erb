<div class="space-y-5">
  <section class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">Manage Admins</h1>
    <%= link_to "New admin", new_admin_path, class: "rounded-full bg-cyan-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-cyan-600" %>
  </section>

  <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="bg-slate-100 text-left text-xs font-semibold uppercase tracking-wide text-slate-600">
          <tr>
            <th class="px-4 py-3">Name</th>
            <th class="px-4 py-3">Email</th>
            <th class="px-4 py-3">Phone</th>
            <th class="px-4 py-3">Last sign-in</th>
            <th class="px-4 py-3">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @admins.each do |admin_user| %>
            <tr class="hover:bg-slate-50">
              <td class="px-4 py-3 font-semibold text-slate-900"><%= admin_user.full_name %></td>
              <td class="px-4 py-3 text-slate-600"><%= admin_user.email %></td>
              <td class="px-4 py-3 text-slate-600"><%= admin_user.phone_number.presence || "-" %></td>
              <td class="px-4 py-3 text-slate-600"><%= admin_user.last_sign_in_at ? l(admin_user.last_sign_in_at, format: :short) : "Never" %></td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-2">
                  <%= link_to "Edit", edit_admin_path(admin_user), class: "rounded-full border border-cyan-200 px-3 py-1 font-semibold text-cyan-700 transition hover:bg-cyan-50" %>
                  <%= button_to "Delete", admin_path(admin_user), method: :delete, data: { turbo_confirm: "Delete this admin?" }, class: "rounded-full border border-rose-200 px-3 py-1 font-semibold text-rose-700 transition hover:bg-rose-50" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
