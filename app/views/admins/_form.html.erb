<%= form_with model: @admin_user, url: @admin_user.persisted? ? admin_path(@admin_user) : admins_path, method: @admin_user.persisted? ? :patch : :post do |f| %>
  <% if @admin_user.errors.any? %>
    <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 p-4">
      <h3 class="text-sm font-bold text-rose-800"><%= t("forms.error_count", count: @admin_user.errors.count) %></h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
        <% @admin_user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :full_name, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.text_field :full_name, required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :email, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.email_field :email, required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4">
    <%= f.label :phone_number, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.telephone_field :phone_number, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-4 rounded-2xl border border-slate-200 bg-slate-50 p-4">
    <h3 class="mb-3 text-sm font-bold uppercase tracking-wide text-slate-700"><%= t("admins.company") %></h3>

    <div class="mb-3">
      <%= f.label :company_name, t("admins.company_name"), class: "mb-1 block text-sm font-semibold text-slate-700" %>
      <%= f.text_field :company_name, value: (@admin_user.managed_gym&.name || params.dig(:user, :company_name)), required: true, class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
    </div>

    <div class="mb-3">
      <%= f.label :company_address, t("admins.company_address"), class: "mb-1 block text-sm font-semibold text-slate-700" %>
      <%= f.text_field :company_address, value: (@admin_user.managed_gym&.address || params.dig(:user, :company_address)), class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
    </div>

    <div>
      <%= f.label :company_currency, t("admins.company_currency"), class: "mb-1 block text-sm font-semibold text-slate-700" %>
      <%= f.select :company_currency, options_for_select(money_currency_options, (@admin_user.managed_gym&.currency || params.dig(:user, :company_currency) || "TND")), {}, class: "w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
    </div>
  </div>

  <div class="mb-4">
    <%= f.label :password, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.password_field :password, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
    <% if @admin_user.persisted? %>
      <p class="mt-1 text-xs text-slate-500"><%= t("admins.password_hint") %></p>
    <% end %>
  </div>

  <div class="mb-5">
    <%= f.label :password_confirmation, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-5 rounded-2xl border border-slate-200 bg-slate-50 p-4">
    <label class="inline-flex items-center gap-3 text-sm font-semibold text-slate-700">
      <%= f.check_box :is_enabled, { class: "h-4 w-4 rounded border-slate-300 text-cyan-600 focus:ring-cyan-500" } %>
      <span><%= t("admins.is_enabled") %></span>
    </label>
    <p class="mt-1 text-xs text-slate-500"><%= t("admins.is_enabled_help") %></p>
  </div>

  <div class="pt-1">
    <%= f.submit class: "rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700" %>
  </div>
<% end %>
