<%= form_with model: @attendance do |f| %>
  <% if @attendance.errors.any? %>
    <div class="mb-5 rounded-2xl border border-rose-200 bg-rose-50 p-4">
      <h3 class="text-sm font-bold text-rose-800"><%= t("forms.error_count", count: @attendance.errors.count) %></h3>
      <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
        <% @attendance.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :training_group_id, "Group", class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.collection_select :training_group_id, @training_groups, :id, :name_with_coach, { prompt: "Select group" }, { required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" } %>
  </div>

  <div class="mb-4">
    <%= f.label :client_id, "Client", class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.collection_select :client_id, @clients, :id, :full_name, { prompt: "Select client" }, { required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" } %>
  </div>

  <div class="mb-4">
    <%= f.label :date, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.date_field :date, required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" %>
  </div>

  <div class="mb-5">
    <%= f.label :status, class: "mb-1 block text-sm font-semibold text-slate-700" %>
    <%= f.select :status, Attendance::STATUSES.map { |s| [t("attendances.statuses.#{s}"), s] }, {}, { required: true, class: "w-full rounded-xl border border-slate-300 px-3 py-2 text-slate-900 outline-none ring-cyan-500 transition focus:border-cyan-500 focus:ring" } %>
  </div>

  <div class="pt-1">
    <%= f.submit class: "rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-700" %>
  </div>
<% end %>
