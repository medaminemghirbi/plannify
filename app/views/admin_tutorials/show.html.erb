<% content_for :title, t("admin_tutorial.title") %>

<section class="mx-auto max-w-5xl space-y-6" data-admin-tutorial="true">
  <header class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <p class="text-xs font-bold uppercase tracking-[0.14em] text-cyan-700"><%= t("admin_tutorial.badge") %></p>
    <h1 class="mt-2 text-2xl font-black tracking-tight text-slate-900"><%= t("admin_tutorial.title") %></h1>
    <p class="mt-2 max-w-3xl text-sm text-slate-600"><%= t("admin_tutorial.subtitle") %></p>
  </header>

  <section class="rounded-3xl border border-cyan-200 bg-cyan-50 p-5 shadow-sm">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-extrabold text-cyan-900"><%= t("admin_tutorial.guided_title") %></h2>
        <p class="mt-1 text-sm text-cyan-800"><%= t("admin_tutorial.guided_hint") %></p>
      </div>

      <div class="flex items-center gap-2">
        <button type="button" id="tutorial-prev" class="inline-flex items-center justify-center rounded-full border border-cyan-300 bg-white px-4 py-2 text-sm font-semibold text-cyan-700 transition hover:bg-cyan-100">
          <%= t("admin_tutorial.previous") %>
        </button>
        <button type="button" id="tutorial-next" class="inline-flex items-center justify-center rounded-full border border-cyan-700 bg-cyan-700 px-4 py-2 text-sm font-semibold text-white transition hover:bg-cyan-600">
          <%= t("admin_tutorial.next") %>
        </button>
      </div>
    </div>

    <p id="tutorial-progress" class="mt-3 text-sm font-semibold text-cyan-900"></p>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-extrabold tracking-tight text-slate-900"><%= t("admin_tutorial.checklist_title") %></h2>
    <ol class="mt-4 space-y-3" id="tutorial-steps" data-progress-template="<%= t("admin_tutorial.progress_of", current: "__CURRENT__", total: "__TOTAL__") %>">
      <% @checklist_items.each_with_index do |item, index| %>
        <li data-tour-step="<%= index %>" tabindex="-1" class="rounded-2xl border border-slate-200 bg-slate-50 p-4 transition duration-200">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <div>
              <p class="text-xs font-extrabold uppercase tracking-[0.14em] text-cyan-700"><%= t("admin_tutorial.step_number", number: index + 1) %></p>
              <h3 class="mt-1 text-base font-bold text-slate-900"><%= item[:title] %></h3>
              <p class="mt-1 text-sm text-slate-600"><%= item[:description] %></p>
            </div>
            <%= link_to item[:cta], item[:path], class: "inline-flex shrink-0 items-center justify-center rounded-full border border-cyan-200 bg-white px-4 py-2 text-sm font-semibold text-cyan-700 transition hover:bg-cyan-50" %>
          </div>
        </li>
      <% end %>
    </ol>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-extrabold tracking-tight text-slate-900"><%= t("admin_tutorial.pro_tips_title") %></h2>
    <ul class="mt-3 space-y-2 text-sm text-slate-700">
      <li>• <%= t("admin_tutorial.pro_tips.tip_1") %></li>
      <li>• <%= t("admin_tutorial.pro_tips.tip_2") %></li>
      <li>• <%= t("admin_tutorial.pro_tips.tip_3") %></li>
    </ul>
  </section>
</section>

<script>
  (function() {
    function initTutorialGuide() {
      var root = document.querySelector('[data-admin-tutorial="true"]');
      if (!root || root.dataset.guideBound === "true") return;
      root.dataset.guideBound = "true";

      var stepsContainer = root.querySelector("#tutorial-steps");
      var progressNode = root.querySelector("#tutorial-progress");
      var prevButton = root.querySelector("#tutorial-prev");
      var nextButton = root.querySelector("#tutorial-next");
      var steps = Array.from(root.querySelectorAll("[data-tour-step]"));
      if (steps.length === 0 || !stepsContainer || !progressNode || !prevButton || !nextButton) return;

      var currentIndex = 0;

      function progressLabel(index) {
        var template = stepsContainer.dataset.progressTemplate || "Step __CURRENT__ / __TOTAL__";
        return template
          .replace("__CURRENT__", String(index + 1))
          .replace("__TOTAL__", String(steps.length));
      }

      function activateStep(index) {
        currentIndex = Math.max(0, Math.min(index, steps.length - 1));

        steps.forEach(function(step, stepIndex) {
          step.classList.remove("ring-2", "ring-cyan-500", "ring-offset-2", "ring-offset-white", "bg-cyan-50", "shadow-md");
          if (stepIndex === currentIndex) {
            step.classList.add("ring-2", "ring-cyan-500", "ring-offset-2", "ring-offset-white", "bg-cyan-50", "shadow-md");
            step.scrollIntoView({ behavior: "smooth", block: "center" });
            step.focus({ preventScroll: true });
          }
        });

        prevButton.disabled = currentIndex === 0;
        prevButton.classList.toggle("opacity-50", prevButton.disabled);
        prevButton.classList.toggle("cursor-not-allowed", prevButton.disabled);

        nextButton.disabled = currentIndex === steps.length - 1;
        nextButton.classList.toggle("opacity-50", nextButton.disabled);
        nextButton.classList.toggle("cursor-not-allowed", nextButton.disabled);

        progressNode.textContent = progressLabel(currentIndex);
      }

      prevButton.addEventListener("click", function() {
        activateStep(currentIndex - 1);
      });

      nextButton.addEventListener("click", function() {
        activateStep(currentIndex + 1);
      });

      document.addEventListener("keydown", function(event) {
        if (!root.contains(document.activeElement)) return;
        if (event.key === "ArrowLeft") activateStep(currentIndex - 1);
        if (event.key === "ArrowRight") activateStep(currentIndex + 1);
      });

      activateStep(0);
    }

    document.addEventListener("turbo:load", initTutorialGuide);
    initTutorialGuide();
  })();
</script>
